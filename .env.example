# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your actual MongoDB connection string (e.g., mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname)
MONGODB_URI=mongodb://localhost:27017/studynook_placeholder

# Authentication
# A long, random string used to safely sign JSON Web Tokens
JWT_SECRET=your_jwt_secret_placeholder_here

# Frontend Integration
# URL of your frontend application to properly configure CORS (e.g., http://localhost:3000 for local dev or https://yourdomain.com for production)
CLIENT_URL=http://localhost:3000
